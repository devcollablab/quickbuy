# ================= DATABASE =================
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_secure_password
DB_NAME=quickbuy

# ================= AUTH / JWT =================
# Generate with: openssl rand -hex 64
SECRET_KEY=your-256-bit-secret-key-here-minimum-32-characters-required
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ================= CORS =================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://yourdomain.com

# ================= EMAIL (OTP) =================
# Option 1: SMTP with App Password (legacy, less secure)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Option 2: OAuth2 (RECOMMENDED - more secure)
# Get from Google Cloud Console: https://console.cloud.google.com/
# 1. Create a project
# 2. Enable Gmail API
# 3. Create OAuth2 credentials (Desktop app type)
# 4. Get refresh token using the OAuth2 flow
EMAIL_USE_OAUTH2=false
GMAIL_OAUTH2_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_OAUTH2_CLIENT_SECRET=your-client-secret
GMAIL_OAUTH2_REFRESH_TOKEN=your-refresh-token

# ================= RAZORPAY =================
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_from_razorpay_dashboard

# ================= CLOUDINARY =================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ================= GOOGLE AUTH =================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ================= ADMIN =================
# Generate with: openssl rand -hex 32
ADMIN_SECRET_KEY=your-admin-secret-key

# ================= REDIS =================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password_if_required

# ================= ENVIRONMENT =================
ENV=dev
